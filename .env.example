# Agent Team Orchestrator - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===========================================
# LLM Provider Configuration
# ===========================================

# Choose your LLM provider: anthropic, openai, ollama
LLM_PROVIDER=anthropic

# Model configuration
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ===========================================
# API Keys
# ===========================================

# Anthropic API Key (for Claude models)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Key (for GPT models or NVIDIA API)
# OPENAI_API_KEY=your-openai-api-key-here

# ===========================================
# Custom API Endpoints (Optional)
# ===========================================

# OpenAI Base URL (for custom endpoints like NVIDIA API)
# OPENAI_BASE_URL=https://api.openai.com/v1

# NVIDIA API example:
# LLM_PROVIDER=openai
# LLM_MODEL=z-ai/glm4.7
# OPENAI_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# Ollama configuration (for local models)
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5-coder-7b-instruct
# OLLAMA_BASE_URL=http://localhost:11434/v1
