# Optional advanced override. The root npm package normally manages its own Python runtime.
# ATO_PYTHON=/absolute/path/to/python

# Optional managed runtime and data root.
# ATO_HOME=/absolute/path/to/ato-data

# Default provider reuses an authenticated Claude Code CLI.
LLM_PROVIDER=claude-cli
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
CLAUDE_CLI_TIMEOUT=300
ATO_MAX_TOOL_ITERATIONS=10

# Anthropic API provider
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# OpenAI or compatible provider
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Ollama OpenAI-compatible endpoint
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Development only. Mutating tools otherwise require a durable approval.
ATO_AUTO_APPROVE_TOOLS=0
