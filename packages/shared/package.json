{
  "name": "@spacesky-cell/ato-shared",
  "version": "0.1.0",
  "description": "Agent Team Orchestrator - Shared types and utilities",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/ --max-warnings=0",
    "clean": "node ../../scripts/clean-package.mjs dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": ["types", "shared"],
  "author": "ATO Contributors",
  "license": "MIT",
  "engines": { "node": ">=18.0.0" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spacesky-cell/agent-team-orchestrator.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/spacesky-cell/agent-team-orchestrator#readme",
  "bugs": { "url": "https://github.com/spacesky-cell/agent-team-orchestrator/issues" }
}
