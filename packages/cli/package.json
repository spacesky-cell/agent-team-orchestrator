{
  "name": "@spacesky-cell/ato-cli",
  "version": "0.1.0",
  "description": "Agent Team Orchestrator - CLI tool",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ato": "dist/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@spacesky-cell/ato-shared": "workspace:0.1.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": ["cli", "agent", "orchestration"],
  "author": "ATO Contributors",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": { "node": ">=18.0.0" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spacesky-cell/agent-team-orchestrator.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/spacesky-cell/agent-team-orchestrator#readme",
  "bugs": { "url": "https://github.com/spacesky-cell/agent-team-orchestrator/issues" }
}
