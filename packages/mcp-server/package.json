{
  "name": "@spacesky-cell/ato-mcp-server",
  "version": "0.2.0",
  "description": "Agent Team Orchestrator - MCP Server implementation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bin": {
      "types": "./dist/bin.d.ts",
      "import": "./dist/bin.js"
    }
  },
  "bin": {
    "ato-mcp": "dist/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/ --max-warnings=0",
    "clean": "node ../../scripts/clean-package.mjs dist"
  },
  "dependencies": {
    "@spacesky-cell/ato-shared": "workspace:0.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": ["mcp", "agent", "orchestration"],
  "author": "ATO Contributors",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": { "node": ">=18.0.0" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spacesky-cell/agent-team-orchestrator.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/spacesky-cell/agent-team-orchestrator#readme",
  "bugs": { "url": "https://github.com/spacesky-cell/agent-team-orchestrator/issues" }
}
